{
  "name": "@ebowwa/claude-code-remake",
  "version": "0.1.0",
  "description": "Claude Code CLI reimplementation in TypeScript + Rust",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-remake": "dist/cli.js"
  },
  "scripts": {
    "build": "bun run build:ts && bun run build:native",
    "build:ts": "bun build ./src/index.ts ./src/cli.ts --outdir ./dist --target bun --minify --splitting",
    "build:native": "cd rust && cargo build --release --target-dir ./target",
    "dev": "bun run --watch src/cli.ts",
    "cli": "bun run src/cli.ts",
    "test": "bun test"
  },
  "files": [
    "dist",
    "native"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "zod": "^3.24.2",
    "yargs": "^17.7.2",
    "chalk": "^5.4.1",
    "ora": "^8.2.0",
    "glob": "^11.0.1",
    "ws": "^8.18.0",
    "eventsource": "^3.0.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/react": "^18.3.18",
    "@types/yargs": "^17.0.33",
    "@types/ws": "^8.5.14",
    "@types/eventsource": "^1.1.15",
    "typescript": "^5.9.3"
  }
}
