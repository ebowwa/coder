{
  "name": "@ebowwa/coder",
  "version": "0.7.102",
  "description": "AI-powered terminal coding assistant",
  "author": "ebowwa",
  "license": "MIT",
  "keywords": [
    "ai",
    "cli",
    "coding",
    "assistant",
    "mcp",
    "terminal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ebowwa/coder.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "coder": "dist/interfaces/ui/terminal/cli/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && bun run build:native && bun run build:ts && bun run build:types && bun run link",
    "build:ts": "VERSION=$(node -p \"require('./package.json').version\") && bun build ./packages/src/index.ts ./packages/src/interfaces/ui/terminal/cli/index.ts --outdir ./dist --target bun --external sharp --external @ebowwa/bun-native-page --external ink --external react --external react-devtools-core --define \"CODER_VERSION=\\\"$VERSION\\\"\"",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "build:native": "cd packages/rust && cargo build --release --target-dir ./target && cd ../.. && bun run build:napi-artifacts",
    "build:napi-artifacts": "napi build --platform --release --target-dir packages/rust/target --manifest-path packages/rust/Cargo.toml --output-dir native --js-package-name @ebowwa/coder-native --const-enum --strip --dts index.d.ts",
    "build:schemas": "bun run packages/src/schemas/generate-json-schemas.ts",
    "link": "bun link || npm link",
    "unlink": "bun unlink || npm unlink -g @ebowwa/coder",
    "dev": "bun run --watch packages/src/interfaces/ui/terminal/cli/index.ts",
    "cli": "bun run packages/src/interfaces/ui/terminal/cli/index.ts",
    "test": "bun test"
  },
  "files": [
    "dist",
    "native",
    "packages/src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./packages/src/schemas/index.ts",
      "import": "./packages/src/schemas/index.ts"
    },
    "./schemas/json/*": "./packages/src/schemas/json/*/*.json",
    "./schemas/json": "./packages/src/schemas/json/index.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@ebowwa/bun-native-page": "0.2.5",
    "@ebowwa/channel-core": "^1.16.0",
    "@ebowwa/channel-telegram": "^1.17.2",
    "@ebowwa/coder-native": "^0.2.1",
    "@ebowwa/daemons": "^0.8.3",
    "@ebowwa/logic-spec": "^1.0.1",
    "@ebowwa/quant-rust": "^0.2.2",
    "@ebowwa/sandbox": "^0.2.3",
    "@ebowwa/state": "^0.2.0",
    "@ebowwa/tui-core": "^1.0.2",
    "@inquirer/prompts": "^8.3.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nomicfoundation/hardhat-ethers": "^4.0.6",
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@swc/wasm": "^1.15.21",
    "@tanstack/react-query": "^5.95.2",
    "chalk": "^5.6.2",
    "ethers": "^6.16.0",
    "eventsource": "^3.0.7",
    "glob": "^12.0.0",
    "hardhat": "^3.2.0",
    "ink": "^5.2.1",
    "ora": "^8.2.0",
    "react": "^18.3.1",
    "react-devtools-core": "^7.0.1",
    "sharp": "^0.34.5",
    "viem": "^2.47.6",
    "wagmi": "^3.6.0",
    "ws": "^8.20.0",
    "yargs": "^17.7.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.11",
    "@types/eventsource": "^1.1.15",
    "@types/react": "^18.3.28",
    "@types/ws": "^8.18.1",
    "@types/yargs": "^17.0.35",
    "@vitest/ui": "^4.1.1",
    "happy-dom": "^20.8.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1",
    "zod-to-json-schema": "^3.25.1"
  },
  "overrides": {
    "form-data": "^4.0.0",
    "undici": "^6.23.0",
    "hono": "^4.12.4",
    "@hono/node-server": "^1.19.10",
    "flatted": "^3.4.0",
    "express-rate-limit": "^8.2.2",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.3"
  }
}
