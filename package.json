{
  "name": "@ebowwa/coder",
  "version": "0.7.86",
  "description": "AI-powered terminal coding assistant",
  "author": "ebowwa",
  "license": "MIT",
  "keywords": [
    "ai",
    "cli",
    "coding",
    "assistant",
    "mcp",
    "terminal"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ebowwa/coder"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "coder": "dist/interfaces/ui/terminal/cli/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && bun run build:native && bun run build:ts && bun run build:types && bun run link",
    "build:ts": "VERSION=$(node -p \"require('./package.json').version\") && bun build ./packages/src/index.ts ./packages/src/interfaces/ui/terminal/cli/index.ts --outdir ./dist --target bun --external sharp --external @ebowwa/bun-native-page --define \"CODER_VERSION=\\\"$VERSION\\\"\"",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "build:native": "cd packages/rust && cargo build --release --target-dir ./target && cd ../.. && bun run build:napi-artifacts",
    "build:napi-artifacts": "napi build --platform --release --target-dir packages/rust/target --manifest-path packages/rust/Cargo.toml --output-dir native --js-package-name @ebowwa/coder-native --const-enum --strip --dts index.d.ts",
    "build:schemas": "bun run packages/src/schemas/generate-json-schemas.ts",
    "link": "bun link || npm link",
    "unlink": "bun unlink || npm unlink -g @ebowwa/coder",
    "dev": "bun run --watch packages/src/interfaces/ui/terminal/cli/index.ts",
    "cli": "bun run packages/src/interfaces/ui/terminal/cli/index.ts",
    "test": "bun test"
  },
  "files": [
    "dist",
    "native",
    "packages/src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./packages/src/schemas/index.ts",
      "import": "./packages/src/schemas/index.ts"
    },
    "./schemas/json/*": "./packages/src/schemas/json/*/*.json",
    "./schemas/json": "./packages/src/schemas/json/index.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@ebowwa/bun-native-page": "^0.2.4",
    "@ebowwa/coder-native": "^0.2.1",
    "@ebowwa/quant-rust": "^0.2.2",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@nomicfoundation/hardhat-ethers": "^4.0.5",
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@tanstack/react-query": "^5.90.21",
    "chalk": "^5.4.1",
    "ethers": "^6.16.0",
    "eventsource": "^3.0.6",
    "glob": "^11.0.1",
    "hardhat": "^3.1.10",
    "ink": "^5.0.1",
    "ora": "^8.2.0",
    "react": "^18.3.1",
    "react-devtools-core": "^7.0.1",
    "sharp": "^0.34.5",
    "viem": "^2.46.3",
    "wagmi": "^3.5.0",
    "ws": "^8.18.0",
    "yargs": "^17.7.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.9",
    "@types/eventsource": "^1.1.15",
    "@types/react": "^18.3.18",
    "@types/ws": "^8.5.14",
    "@types/yargs": "^17.0.33",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.7.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod-to-json-schema": "^3.25.1"
  }
}
