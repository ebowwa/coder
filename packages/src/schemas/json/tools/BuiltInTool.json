{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ebowwa.github.io/coder/schemas/BuiltInTool.json",
  "$ref": "#/definitions/BuiltInTool",
  "definitions": {
    "BuiltInTool": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "file",
            "execution",
            "search",
            "workflow",
            "code-intelligence",
            "interaction",
            "planning",
            "git"
          ]
        },
        "parameters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string"
              },
              "required": {
                "type": "boolean"
              },
              "type": {
                "type": "string",
                "enum": [
                  "string",
                  "number",
                  "boolean",
                  "array",
                  "object"
                ]
              },
              "default": {},
              "enum": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "name",
              "description",
              "required"
            ],
            "additionalProperties": false
          }
        },
        "operations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "name",
        "description",
        "category"
      ],
      "additionalProperties": false
    }
  },
  "title": "BuiltInTool Schema"
}