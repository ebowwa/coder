{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ebowwa.github.io/coder/schemas/tools/index.json",
  "title": "tools Schemas Index",
  "description": "JSON Schema definitions for tools types",
  "definitions": {
    "ToolCategory": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/ToolCategory.json",
      "$ref": "#/definitions/ToolCategory",
      "definitions": {
        "ToolCategory": {
          "type": "string",
          "enum": [
            "file",
            "execution",
            "search",
            "workflow",
            "code-intelligence",
            "interaction",
            "planning",
            "git"
          ]
        }
      },
      "title": "ToolCategory Schema"
    },
    "BuiltInTool": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/BuiltInTool.json",
      "$ref": "#/definitions/BuiltInTool",
      "definitions": {
        "BuiltInTool": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string"
            },
            "category": {
              "type": "string",
              "enum": [
                "file",
                "execution",
                "search",
                "workflow",
                "code-intelligence",
                "interaction",
                "planning",
                "git"
              ]
            },
            "parameters": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "description": {
                    "type": "string"
                  },
                  "required": {
                    "type": "boolean"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "string",
                      "number",
                      "boolean",
                      "array",
                      "object"
                    ]
                  },
                  "default": {},
                  "enum": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "name",
                  "description",
                  "required"
                ],
                "additionalProperties": false
              }
            },
            "operations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "name",
            "description",
            "category"
          ],
          "additionalProperties": false
        }
      },
      "title": "BuiltInTool Schema"
    },
    "ToolExecutionConfig": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/ToolExecutionConfig.json",
      "$ref": "#/definitions/ToolExecutionConfig",
      "definitions": {
        "ToolExecutionConfig": {
          "type": "object",
          "properties": {
            "timeout_ms": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "default_timeout": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "max_timeout": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "chrome_bridge": {
              "type": "boolean"
            },
            "tool_call_timeout_ms": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "max_retries": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "timeout_ms",
            "default_timeout",
            "max_timeout",
            "chrome_bridge",
            "tool_call_timeout_ms",
            "max_retries"
          ],
          "additionalProperties": false
        }
      },
      "title": "ToolExecutionConfig Schema"
    },
    "ToolResult": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/ToolResult.json",
      "$ref": "#/definitions/ToolResult",
      "definitions": {
        "ToolResult": {
          "type": "object",
          "properties": {
            "tool_use_id": {
              "type": "string"
            },
            "content": {
              "type": "string"
            },
            "is_error": {
              "type": "boolean"
            },
            "output_mode": {
              "type": "string",
              "enum": [
                "content",
                "files_with_matches",
                "count"
              ]
            }
          },
          "required": [
            "content"
          ],
          "additionalProperties": false
        }
      },
      "title": "ToolResult Schema"
    }
  }
}