{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ebowwa.github.io/coder/schemas/permissions/index.json",
  "title": "permissions Schemas Index",
  "description": "JSON Schema definitions for permissions types",
  "definitions": {
    "PermissionMode": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/PermissionMode.json",
      "$ref": "#/definitions/PermissionMode",
      "definitions": {
        "PermissionMode": {
          "type": "string",
          "enum": [
            "default",
            "ask",
            "acceptEdits",
            "bypassPermissions",
            "bypass",
            "dontAsk",
            "interactive",
            "plan",
            "auto"
          ]
        }
      },
      "title": "PermissionMode Schema"
    },
    "PermissionRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/PermissionRequest.json",
      "$ref": "#/definitions/PermissionRequest",
      "definitions": {
        "PermissionRequest": {
          "type": "object",
          "properties": {
            "requestId": {
              "type": "string"
            },
            "toolName": {
              "type": "string"
            },
            "toolInput": {
              "type": "object",
              "additionalProperties": {}
            },
            "description": {
              "type": "string"
            },
            "riskLevel": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ]
            },
            "sessionId": {
              "type": "string"
            },
            "timestamp": {
              "type": "number"
            }
          },
          "required": [
            "requestId",
            "toolName",
            "riskLevel",
            "timestamp"
          ],
          "additionalProperties": false
        }
      },
      "title": "PermissionRequest Schema"
    },
    "PermissionResponse": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/PermissionResponse.json",
      "$ref": "#/definitions/PermissionResponse",
      "definitions": {
        "PermissionResponse": {
          "type": "object",
          "properties": {
            "requestId": {
              "type": "string"
            },
            "decision": {
              "type": "string",
              "enum": [
                "allow",
                "deny",
                "ask"
              ]
            },
            "reason": {
              "type": "string"
            },
            "modifiedInput": {
              "type": "object",
              "additionalProperties": {}
            },
            "remember": {
              "type": "boolean"
            },
            "rememberDuration": {
              "type": "number"
            }
          },
          "required": [
            "requestId",
            "decision"
          ],
          "additionalProperties": false
        }
      },
      "title": "PermissionResponse Schema"
    },
    "RiskLevel": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/RiskLevel.json",
      "$ref": "#/definitions/RiskLevel",
      "definitions": {
        "RiskLevel": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      },
      "title": "RiskLevel Schema"
    },
    "PermissionToolChoice": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/PermissionToolChoice.json",
      "$ref": "#/definitions/PermissionToolChoice",
      "definitions": {
        "PermissionToolChoice": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "auto"
                }
              },
              "required": [
                "type"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "any"
                }
              },
              "required": [
                "type"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "none"
                }
              },
              "required": [
                "type"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "tool"
                },
                "name": {
                  "type": "string"
                }
              },
              "required": [
                "type",
                "name"
              ],
              "additionalProperties": false
            }
          ]
        }
      },
      "title": "PermissionToolChoice Schema"
    }
  }
}