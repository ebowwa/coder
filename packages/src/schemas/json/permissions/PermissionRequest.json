{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ebowwa.github.io/coder/schemas/PermissionRequest.json",
  "$ref": "#/definitions/PermissionRequest",
  "definitions": {
    "PermissionRequest": {
      "type": "object",
      "properties": {
        "requestId": {
          "type": "string"
        },
        "toolName": {
          "type": "string"
        },
        "toolInput": {
          "type": "object",
          "additionalProperties": {}
        },
        "description": {
          "type": "string"
        },
        "riskLevel": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "sessionId": {
          "type": "string"
        },
        "timestamp": {
          "type": "number"
        }
      },
      "required": [
        "requestId",
        "toolName",
        "riskLevel",
        "timestamp"
      ],
      "additionalProperties": false
    }
  },
  "title": "PermissionRequest Schema"
}