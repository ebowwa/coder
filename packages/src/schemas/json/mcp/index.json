{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ebowwa.github.io/coder/schemas/mcp/index.json",
  "title": "mcp Schemas Index",
  "description": "JSON Schema definitions for mcp types",
  "definitions": {
    "MCPServerConfig": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/MCPServerConfig.json",
      "$ref": "#/definitions/MCPServerConfig",
      "definitions": {
        "MCPServerConfig": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "stdio",
                "sse",
                "http",
                "ws"
              ]
            },
            "command": {
              "type": "string"
            },
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "env": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "timeout": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "disabled": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "title": "MCPServerConfig Schema"
    },
    "MCPTool": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/MCPTool.json",
      "$ref": "#/definitions/MCPTool",
      "definitions": {
        "MCPTool": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string"
            },
            "inputSchema": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "object"
                },
                "properties": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string"
                      },
                      "description": {
                        "type": "string"
                      },
                      "enum": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "default": {},
                      "items": {
                        "$ref": "#/definitions/MCPTool/properties/inputSchema/properties/properties/additionalProperties"
                      },
                      "properties": {
                        "type": "object",
                        "additionalProperties": {
                          "$ref": "#/definitions/MCPTool/properties/inputSchema/properties/properties/additionalProperties"
                        }
                      },
                      "required": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    },
                    "required": [
                      "type"
                    ],
                    "additionalProperties": false
                  }
                },
                "required": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "additionalProperties": {
                  "type": "boolean"
                }
              },
              "required": [
                "type",
                "properties"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "name",
            "description",
            "inputSchema"
          ],
          "additionalProperties": false
        }
      },
      "title": "MCPTool Schema"
    },
    "JSONRPCRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/JSONRPCRequest.json",
      "$ref": "#/definitions/JSONRPCRequest",
      "definitions": {
        "JSONRPCRequest": {
          "type": "object",
          "properties": {
            "jsonrpc": {
              "type": "string",
              "const": "2.0"
            },
            "id": {
              "type": [
                "string",
                "number"
              ]
            },
            "method": {
              "type": "string"
            },
            "params": {}
          },
          "required": [
            "jsonrpc",
            "id",
            "method"
          ],
          "additionalProperties": false
        }
      },
      "title": "JSONRPCRequest Schema"
    },
    "JSONRPCResponse": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/JSONRPCResponse.json",
      "$ref": "#/definitions/JSONRPCResponse",
      "definitions": {
        "JSONRPCResponse": {
          "type": "object",
          "properties": {
            "jsonrpc": {
              "type": "string",
              "const": "2.0"
            },
            "id": {
              "type": [
                "string",
                "number"
              ]
            },
            "result": {},
            "error": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer"
                },
                "message": {
                  "type": "string"
                },
                "data": {}
              },
              "required": [
                "code",
                "message"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "jsonrpc",
            "id"
          ],
          "additionalProperties": false
        }
      },
      "title": "JSONRPCResponse Schema"
    },
    "ToolCallRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/ToolCallRequest.json",
      "$ref": "#/definitions/ToolCallRequest",
      "definitions": {
        "ToolCallRequest": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "arguments": {
              "type": "object",
              "additionalProperties": {}
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        }
      },
      "title": "ToolCallRequest Schema"
    },
    "ToolCallResponse": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/ToolCallResponse.json",
      "$ref": "#/definitions/ToolCallResponse",
      "definitions": {
        "ToolCallResponse": {
          "type": "object",
          "properties": {
            "content": {
              "type": "array",
              "items": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "const": "text"
                      },
                      "text": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "type",
                      "text"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "const": "image"
                      },
                      "data": {
                        "type": "string"
                      },
                      "mimeType": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "type",
                      "data",
                      "mimeType"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "const": "resource"
                      },
                      "resource": {
                        "type": "object",
                        "properties": {
                          "uri": {
                            "type": "string"
                          },
                          "mimeType": {
                            "type": "string"
                          },
                          "text": {
                            "type": "string"
                          },
                          "blob": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "uri"
                        ],
                        "additionalProperties": false
                      }
                    },
                    "required": [
                      "type",
                      "resource"
                    ],
                    "additionalProperties": false
                  }
                ]
              }
            },
            "isError": {
              "type": "boolean"
            }
          },
          "required": [
            "content"
          ],
          "additionalProperties": false
        }
      },
      "title": "ToolCallResponse Schema"
    },
    "TransportType": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "$id": "https://ebowwa.github.io/coder/schemas/TransportType.json",
      "$ref": "#/definitions/TransportType",
      "definitions": {
        "TransportType": {
          "type": "string",
          "enum": [
            "stdio",
            "sse",
            "http",
            "ws"
          ]
        }
      },
      "title": "TransportType Schema"
    }
  }
