{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ebowwa.github.io/coder/schemas/RateLimitConfig.json",
  "$ref": "#/definitions/RateLimitConfig",
  "definitions": {
    "RateLimitConfig": {
      "type": "object",
      "properties": {
        "requestsPerMinute": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "tokensPerMinute": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "retryAfterMs": {
          "type": "integer",
          "minimum": 0
        },
        "maxRetries": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "requestsPerMinute",
        "tokensPerMinute",
        "retryAfterMs",
        "maxRetries"
      ],
      "additionalProperties": false
    }
  },
  "title": "RateLimitConfig Schema"
}