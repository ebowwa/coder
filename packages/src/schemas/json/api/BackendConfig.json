{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ebowwa.github.io/coder/schemas/BackendConfig.json",
  "$ref": "#/definitions/BackendConfig",
  "definitions": {
    "BackendConfig": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "anthropic",
            "bedrock",
            "vertex",
            "foundry"
          ]
        },
        "description": {
          "type": "string"
        },
        "envCheck": {
          "type": "string"
        },
        "priority": {
          "type": "integer",
          "exclusiveMinimum": 0
        }
      },
      "required": [
        "id",
        "description",
        "envCheck",
        "priority"
      ],
      "additionalProperties": false
    }
  },
  "title": "BackendConfig Schema"
}