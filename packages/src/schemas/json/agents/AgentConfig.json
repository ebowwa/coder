{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ebowwa.github.io/coder/schemas/AgentConfig.json",
  "$ref": "#/definitions/AgentConfig",
  "definitions": {
    "AgentConfig": {
      "type": "object",
      "properties": {
        "agentType": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "color": {
          "type": "string"
        },
        "systemPrompt": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "permissionMode": {
          "type": "string",
          "enum": [
            "ask",
            "bypass"
          ]
        },
        "capabilities": {
          "type": "object",
          "properties": {
            "canSpawnAgents": {
              "type": "boolean"
            },
            "canUseBash": {
              "type": "boolean"
            },
            "canEditFiles": {
              "type": "boolean"
            },
            "canAccessNetwork": {
              "type": "boolean"
            },
            "canUseMCP": {
              "type": "boolean"
            },
            "maxConcurrency": {
              "type": "integer",
              "exclusiveMinimum": 0
            }
          },
          "additionalProperties": false
        },
        "maxTurns": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "workingDirectory": {
          "type": "string"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "agentType"
      ],
      "additionalProperties": false
    }
  },
  "title": "AgentConfig Schema"
}