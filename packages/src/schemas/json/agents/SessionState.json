{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ebowwa.github.io/coder/schemas/SessionState.json",
  "$ref": "#/definitions/SessionState",
  "definitions": {
    "SessionState": {
      "type": "object",
      "properties": {
        "sessionId": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "idle",
            "paused",
            "completed",
            "error"
          ]
        },
        "startTime": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "endTime": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "messageCount": {
          "type": "integer",
          "minimum": 0
        },
        "totalTokens": {
          "type": "integer",
          "minimum": 0
        },
        "costUSD": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "sessionId",
        "status",
        "startTime",
        "messageCount",
        "totalTokens",
        "costUSD"
      ],
      "additionalProperties": false
    }
  },
  "title": "SessionState Schema"
}