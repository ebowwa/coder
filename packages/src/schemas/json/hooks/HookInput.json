{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ebowwa.github.io/coder/schemas/HookInput.json",
  "$ref": "#/definitions/HookInput",
  "definitions": {
    "HookInput": {
      "type": "object",
      "properties": {
        "event": {
          "type": "string",
          "enum": [
            "SessionStart",
            "SessionEnd",
            "PreToolUse",
            "PostToolUse",
            "PostToolUseFailure",
            "PrePrompt",
            "PostPrompt",
            "Notification",
            "TeammateIdle",
            "UserPromptSubmit",
            "ConfigChange",
            "WorktreeCreate"
          ]
        },
        "tool_name": {
          "type": "string"
        },
        "tool_input": {
          "type": "object",
          "additionalProperties": {}
        },
        "tool_result": {},
        "tool_result_is_error": {
          "type": "boolean"
        },
        "error": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "timestamp": {
          "type": "number"
        }
      },
      "required": [
        "event",
        "timestamp"
      ],
      "additionalProperties": false
    }
  },
  "title": "HookInput Schema"
}