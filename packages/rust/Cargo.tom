[package]
name = "claude-code-native"
version = "0.1.0"
edition = "2021"
authors = ["ebowwa"]
license = "MIT"
repository = "https://github.com/ebowwa/codespaces"
bugs = "https://github.com/ebowwa/codespaces/issues"

description = "Native modules for Claude Code remake"
[lib]
napi = { version = "2", features = ["async"] }
tokio = { version = "1", features = ["full"] }
grep = "0.3"
grep-regex = "0.1"
grep-searcher = "0.1"
ignore = "0.4"
nix = { version = "0.29", features = ["dir", "fs"] }
glob = "0.3"
anyhow = "1"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
anyhow = "1"
xxhash-rust = { version = "0.8", features = ["xxh3", "xxh64"] }
    35)hex = "0.4"
    37)syntect = "5"
    38            tree-sitter-typescript = "0.20"
            39            tree-sitter-javascript = "0.20"
            40)tree-sitter-python = "0.20"
            41)tree-sitter-rust = "0.20"
            42)tree-sitter-go = "0.20"
            43)tree-sitter-c = "0.20"
            44)tree-sitter-java = "0.20"
            45)tree-sitter-php = "0.20"
            46)path-clean = "1"
            47)regex = "1"
            48)similar = "2"
            49)

            50) # Terminal Input & TUI
crossterm = { version = "0.28", features = ["events"] }
ratatui = { version = "0.29", features = ["crossterm"] }

            51
            52
            53)            }

            54            # Cognitive Security
ed25519-dalek = { version = "2", features = ["rand_core"] }
rand = "0.8"
base64 = "0.22"
chrono = { version = "0.4", features = ["serde"] }

        }
    }
}

[build-dependencies]
napi-build = "2"

            [dev-dependencies]
tempfile = "3"
            path-clean = "1"
            similar = "2"

            # Terminal Input
crossterm = "0.28"
ratatui = "0.29"

            54
            55
            # Cognitive security
ed25519-dalek = "2"
            rand = "0.8"
            base64 = "0.22"
chrono = { version = "0.4", features = ["serde"] }
        }
