{
  "name": "@ebowwa/compute-engine",
  "version": "0.1.0",
  "description": "High-performance hash computation CLI with Rust native module",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "compute-engine": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun run build:native && bun run build:ts",
    "build:native": "cargo build --release && cp target/release/libcompute_engine.* native/ 2>/dev/null || cp target/release/compute_engine.dll native/ 2>/dev/null || true",
    "build:ts": "bun build ./src/cli.tsx ./src/index.ts --outdir ./dist --target bun --external ink --external react",
    "dev": "bun run src/cli.tsx",
    "test": "bun test",
    "bench": "bun run src/cli.tsx bench"
  },
  "dependencies": {
    "ink": "^4.4.1",
    "react": "^18.2.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "chokidar": "^3.6.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "bun-types": "^1.1.0",
    "typescript": "^5.4.0"
  },
  "files": [
    "dist",
    "native",
    "src"
  ],
  "keywords": [
    "hash",
    "xxhash",
    "sha256",
    "blake3",
    "rust",
    "native",
    "cli"
  ],
  "license": "MIT"
}
