{
  "name": "snipurl",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch server/index.ts",
    "dev:client": "cd client && bun run dev",
    "build": "bun run build:server && bun run build:client",
    "build:server": "bun build server/index.ts --outdir dist/server",
    "build:client": "cd client && bun run build",
    "start": "NODE_ENV=production bun server/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "hono": "^4.6.0",
    "nanoid": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "concurrently": "^8.2.0",
    "typescript": "^5.6.0",
    "bun-types": "^1.1.0"
  }
}
