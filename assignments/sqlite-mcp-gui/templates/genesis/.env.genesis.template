# ============================================================================
# Genesis Server Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# ============================================================================

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------

# Port for the dashboard/API
PORT=3000

# Host binding (0.0.0.0 for all interfaces, required for Tailscale access)
HOST=0.0.0.0

# ----------------------------------------------------------------------------
# Hetzner API Configuration
# ----------------------------------------------------------------------------

# Your Hetzner Cloud API token
# Create at: https://console.hetzner.cloud/projects/_/security/tokens
# Required permissions: Read & Write for Servers, SSH Keys, Volumes
HETZNER_API_TOKEN=your_hetzner_api_token_here

# Default SSH key name (will be created if doesn't exist)
HETZNER_SSH_KEY_NAME=genesis-default

# Default server type for worker nodes
# See: https://www.hetzner.com/cloud#pricing
# Examples: cpx11 (€3.72/mo), cpx21 (€7.45/mo), cpx31 (€14.90/mo)
HETZNER_DEFAULT_TYPE=cpx11

# Default datacenter/region
# Examples: nbg1 (Nuremberg), fsn1 (Falkenstein), hel1 (Helsinki)
HETZNER_DEFAULT_REGION=nbg1

# Default OS image
HETZNER_DEFAULT_IMAGE=ubuntu-24.04

# ----------------------------------------------------------------------------
# Tailscale Configuration
# ----------------------------------------------------------------------------

# Tailscale Auth Key (for automated setup)
# Get from: https://login.tailscale.com/admin/settings/keys
# Leave empty to authenticate manually via SSH
TAILSCALE_AUTH_KEY=

# Tailscale hostname prefix (will use hostname if empty)
TAILSCALE_HOSTNAME_PREFIX=genesis

# ----------------------------------------------------------------------------
# Worker Node Configuration
# ----------------------------------------------------------------------------

# Maximum number of concurrent worker nodes
MAX_WORKER_NODES=10

# Default project/repo for worker nodes
WORKER_REPO_URL=https://github.com/your-org/seed.git
WORKER_REPO_BRANCH=main

# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------

# Dashboard password (basic auth)
# Leave empty to disable authentication (not recommended for production)
DASHBOARD_PASSWORD=

# Allowed Tailscale IP ranges (comma-separated)
# Leave empty to allow any Tailscale connection
ALLOWED_TAILSCALE_RANGES=100.64.0.0/10

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------

# Enable debug logging
DEBUG=false

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable metrics endpoint
ENABLE_METRICS=true

# ----------------------------------------------------------------------------
# Database (SQLite by default)
# ----------------------------------------------------------------------------

# Database path
DB_PATH=/root/genesis/data/genesis.db
